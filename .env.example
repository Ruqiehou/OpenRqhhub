# ============================================================
#  GitLocal 环境配置示例
#  复制本文件为 .env 并按需修改
# ============================================================

# ----- 后端配置 -----

# 后端监听地址
#   Windows 本地部署: localhost (仅本机访问)
#   Linux  公网部署: 0.0.0.0 (对外开放)
HOST=localhost

# 后端端口
PORT=3001

# ----- 前端配置 -----

# Vite 开发服务器监听地址
#   Windows 本地部署: localhost
#   Linux  公网部署: 0.0.0.0
VITE_HOST=localhost

# 前端端口
VITE_PORT=5173

# 前端调用后端的完整地址
#   Windows 本地部署: http://localhost:3001/api
#   Linux  公网部署: http://<你的公网IP>:3001/api
VITE_API_BASE_URL=http://localhost:3001/api

# ============================================================
#  快速参考
# ============================================================
#
#  场景一: Windows 本机开发（默认）
#    HOST=localhost
#    VITE_HOST=localhost
#    VITE_API_BASE_URL=http://localhost:3001/api
#    访问: http://localhost:5173
#
#  场景二: Linux 公网服务器部署
#    HOST=0.0.0.0
#    VITE_HOST=0.0.0.0
#    VITE_API_BASE_URL=http://123.45.67.89:3001/api   ← 替换为你的公网IP
#    访问: http://123.45.67.89:5173
#
#  场景三: Linux 局域网部署
#    HOST=0.0.0.0
#    VITE_HOST=0.0.0.0
#    VITE_API_BASE_URL=http://192.168.1.100:3001/api  ← 替换为服务器内网IP
#    访问: http://192.168.1.100:5173
#
# ============================================================
